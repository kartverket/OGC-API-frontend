{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "Fylker",
  "description": "Feltdefinisjoner for fylke-samlingen (administrative enheter – fylker).",
  "properties": {
    "objid": {
      "type": "string",
      "title": "Objekt-ID",
      "description": "Unik identifikator for objektet.",
      "x-ogc-role": "id",
      "x-ogc-sortable": false,
      "x-ogc-filterable": false
    },
    "datafangstdato": {
      "type": "string",
      "format": "date",
      "title": "Datafangstdato",
      "description": "Dato når dataene ble fanget.",
      "x-ogc-sortable": true,
      "x-ogc-filterable": true
    },
    "oppdateringsdato": {
      "type": "string",
      "format": "date",
      "title": "Oppdateringsdato",
      "description": "Dato for siste oppdatering av objektet.",
      "x-ogc-sortable": true,
      "x-ogc-filterable": true
    },
    "datauttaksdato": {
      "type": "string",
      "format": "date",
      "title": "Datauttaksdato",
      "description": "Dato for datauttaket.",
      "x-ogc-sortable": true,
      "x-ogc-filterable": true
    },
    "opphav": {
      "type": "string",
      "title": "Opphav",
      "description": "Kilde eller opphav til dataene.",
      "x-ogc-sortable": false,
      "x-ogc-filterable": true
    },
    "malemetode": {
      "type": "string",
      "title": "Målemetode",
      "description": "Metode brukt for måling.",
      "x-ogc-sortable": false,
      "x-ogc-filterable": true
    },
    "noyaktighet": {
      "type": "integer",
      "title": "Nøyaktighet",
      "description": "Nøyaktighet i meter.",
      "x-ogc-sortable": true,
      "x-ogc-filterable": true
    },
    "synbarhet": {
      "type": "string",
      "title": "Synbarhet",
      "description": "Objektets synbarhet.",
      "x-ogc-sortable": false,
      "x-ogc-filterable": true
    },
    "medium": {
      "type": "string",
      "title": "Medium",
      "description": "Medium objektet befinner seg i.",
      "x-ogc-sortable": false,
      "x-ogc-filterable": true
    },
    "verifiseringsdato": {
      "type": "string",
      "format": "date",
      "title": "Verifiseringsdato",
      "description": "Dato for verifisering av objektet.",
      "x-ogc-sortable": true,
      "x-ogc-filterable": true
    },
    "informasjon": {
      "type": "string",
      "title": "Informasjon",
      "description": "Tilleggsinformasjon om objektet.",
      "x-ogc-sortable": false,
      "x-ogc-filterable": false
    },
    "fylkesnummer": {
      "type": "string",
      "title": "Fylkesnummer",
      "description": "Tresifret nummeridentifikasjon for fylke.",
      "x-ogc-sortable": true,
      "x-ogc-filterable": true
    },
    "fylkesnavn": {
      "type": "string",
      "title": "Fylkesnavn",
      "description": "Navn på fylket.",
      "x-ogc-sortable": true,
      "x-ogc-filterable": true
    }
  }
}
